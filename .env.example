OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
GROQ_API_KEY2=
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_STORAGE_BUCKET=licitapro-uploads
APP_VERSION=dev
APP_CHANNEL=local
APP_COMMIT=local
APP_DEPLOYED_AT=

# Parser local sem API.
# Mantem a IA como fallback quando a confianca local for baixa.
USAR_PARSER_LOCAL=true
PARSER_FALLBACK_API=true
PARSER_MIN_CONFIANCA=70
PARSER_MAX_CHARS_FALLBACK=80000

# OCR automático no upload de PDFs escaneados.
OCR_HABILITADO=true
OCR_MIN_CHAR=120
OCR_MAX_PAGINAS=20
OCR_DPI=220

# Fallback local (sem API externa) via Ollama ou endpoint OpenAI-compat.
# Para usar com Ollama:
# 1) instale e rode o Ollama
# 2) `ollama pull llama3.1:8b`
# 3) ative as variáveis abaixo
LOCAL_LLM_ENABLED=false
LOCAL_LLM_PROVIDER=ollama
LOCAL_LLM_BASE_URL=http://127.0.0.1:11434
LOCAL_LLM_MODEL=llama3.1:8b
